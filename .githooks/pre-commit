#!/bin/sh

set -eu

if ! command -v git >/dev/null 2>&1; then
    echo "Git is required to run this hook."
    exit 1
fi

if [ ! -x vendor/bin/pint ]; then
    echo "Laravel Pint is not installed. Run composer install first."
    exit 1
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACMR -- '*.php')

if [ -z "$staged_files" ]; then
    exit 0
fi

echo "Linting staged PHP files..."
printf '%s\n' "$staged_files" | while IFS= read -r file; do
    if [ -z "$file" ] || [ ! -f "$file" ]; then
        continue
    fi

    php -l "$file" >/dev/null
done

echo "Checking formatting with Laravel Pint..."
vendor/bin/pint --test $staged_files